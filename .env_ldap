OAUTH_TOKEN = 
ORG_ID = 1234567

#   Адрес контролера домена для подключения по LDAP протоколу.
#    Eсли в AD несколько доменов, то обязательно DNS имя, в Linix должно быть настроено разрешение имен через локальный DNS.
#    Если домен один, можно указывать IP адрес.

LDAP_HOST = 'dc01.domain.ru'
# Использовать ли LDAPS протокол для подключения к LDAP серверу, порт для LDAPS должен быть 636
LDAPS_ENABLED = False
# Порт глобального каталога (если в AD один домен, то можно использовать 389 порт)
LDAP_PORT = 3268
# Учетка, от имени которорой будет работать коннектор в формате netbios_domain_name\samaccountname
LDAP_USER = 'domain\admin'
LDAP_PASSWORD = 'P@ssw0rd123456'

# Откуда в каталоге будет начинаться поиск пользователей, которые были мигрированы в Яндекс 360
LDAP_BASE_DN = 'DC=domain,DC=ru'
# Фильтр поиска учеток, которые были мигрированы в Яндекс 360
LDAP_SEARCH_FILTER = (memberOf=CN=Yandex360,OU=Groups,OU=Office,DC=domain,DC=ru)

# Список атрибутов, которые возращаются в результате поиска
ATTRIB_LIST = distinguishedName,mail,displayName,department,objectCategory,sAMAccountName,cn,description

# Корневой OU, в котором будет начинаться поиск OU для миграции в Яндекс 360
ROOT_OU = "OU=Head,DC=domain,DC=ru;OU=Office,DC=domain,DC=ru"

# Файл для выгрузки данных о департаментах из Active Directory
AD_DEPS_OUT_FILE = "ad_deps.txt"

# Файл для выгрузки данных о пользователях из Active Directory
AD_DATA_OUT_FILE = "ad_data.txt"

# Файл для выгрузки данных о пользователях из API Яндекс 360
API_DATA_OUT_FILE = "api_data.txt"

# Режим тестового прогона
DRY_RUN = False

# Загружать ли данные для загрузки в Яндекс 360 из файла
LOAD_AD_DATA_FROM_FILE = false

# Не удалять ли пустые externalId в Яндекс 360
KEEP_EMPTY_EXTERNAL_ID_IN_Y360 = True
